# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
RUN_DB_PUSH_ON_START=true

# App DB (Railway volume path example: /data/sqlite.db)
DATABASE_URL=sqlite.db
OPENAI_API_KEY=your_openai_api_key
ADMIN_SECRET=super_secret

OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=nvidia/nemotron-3-super-120b-a12b

# NVIDIA Specific Keys
NVIDIA_ASR_API_KEY=your_parakeet_api_key_here
NVIDIA_EMBED_API_KEY=your_embedqa_api_key_here

# Railway Bucket Configuration
BUCKET=my-bucket-name
REGION=auto
ENDPOINT=https://storage.railway.app
ACCESS_KEY_ID=your-access-key-id
SECRET_ACCESS_KEY=your-secret-access-key
